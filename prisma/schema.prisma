generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  TELEGRAM
  FARCASTER
  WEB
}

enum AuthProvider {
  EVM_EOA
  THIRDWEB_SMART_WALLET
  TON_WALLET
  TELEGRAM
  FARCASTER
  UNKNOWN
}

enum PolymarketWalletType {
  EOA
  POLY_PROXY
  GNOSIS_SAFE
  POLY_1271
}

enum PolymarketAccountStatus {
  LINKED
  READY
  DISCONNECTED
  ERROR
}

enum PolymarketChallengePurpose {
  LINK
  UNLINK
}

enum PolymarketPositionState {
  OPEN
  CLOSED
}

enum UsageEventType {
  PAGE_VIEW
  HEARTBEAT
  AUTH_CONNECT
  AUTH_DISCONNECT
  PROFILE_CLAIM
  MARKET_VIEW
  MARKET_OPEN_MARGIN
  MARGIN_REQUEST
  VAULT_DEPOSIT
  PULSE_POST
  PULSE_SIGNAL
  PULSE_FOLLOW
  SUPPORT_OPEN
  MINIAPP_OPEN
}

enum MarketSource {
  POLYMARKET
  KALSHI
}

enum MarketStatus {
  ACTIVE
  CLOSED
  SETTLED
  CANCELLED
}

enum PositionSide {
  YES
  NO
}

enum PositionStatus {
  PENDING_EXECUTION
  EXECUTED
  CLOSED
  FAILED
  CANCELLED
}

enum ExecutionMode {
  SPOT
  MARGIN
}

enum ExecutionTargetType {
  POSITION
  COPY_TRADE
}

enum ExecutionAttemptStatus {
  BLOCKED
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum PolymarketMarginExecutionState {
  AUTHORIZED
  RESERVED
  WALLET_DEPLOYING
  WALLET_COMMIT_REQUIRED
  WALLET_COMMITTED
  FUNDED
  ORDER_PREPARED
  ORDER_SUBMITTED
  FILL_CONFIRMED
  SECURED
  OPEN
  CLOSING
  CLOSED
  CANCELLED
  FAILED
  RECONCILIATION_REQUIRED
}

enum PolymarketCloseReason {
  VOLUNTARY
  MANDATORY
  LIQUIDATION
  RESOLUTION
  STOP_LOSS
  TAKE_PROFIT
}

enum PolymarketCloseStage {
  AUTHORIZED
  SHARES_RELEASING
  SHARES_RELEASED
  ORDER_PREPARED
  ORDER_SUBMITTED
  FILL_CONFIRMED
  PROCEEDS_RETURNING
  SETTLING
  NO_FILL_RETURNING
  NO_FILL_RESTORING
  RESTORED
  AUCTION_REQUIRED
  RESOLUTION_REDEEMING
  CLOSED
  FAILED
}

enum MarginMarketPolicyStatus {
  DRAFT
  APPROVED
  PAUSED
}

enum TradeSignalSide {
  YES
  NO
}

enum TradeSignalStatus {
  PUBLISHED
  CANCELLED
  EXPIRED
}

enum TradeSignalSource {
  TELEGRAM
  FARCASTER
  WEB
}

enum SignalReplyStatus {
  PUBLISHED
  HIDDEN
}

enum SignalReactionType {
  LIKE
}

enum PulsePostStatus {
  PUBLISHED
  HIDDEN
}

enum PulsePostReactionType {
  LIKE
}

enum CopyTradeStatus {
  PENDING_EXECUTION
  EXECUTED
  FAILED
  CANCELLED
}

enum ContractRole {
  MARGIN_VAULT
  EXECUTION_ADAPTER
  COLLATERAL_TOKEN
}

enum ContractTransactionStatus {
  PREPARED
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum TelegramChatRole {
  SUPPORT
  MARKET_ALERTS
  GENERAL
}

enum ContractTransactionType {
  COLLATERAL_APPROVAL
  DEPOSIT
  MARGIN_INTENT
  CLOSE_INTENT
  LIQUIDATION
}

enum OmnistonQuoteStatus {
  REQUESTED
  QUOTED
  NO_QUOTE
  FAILED
  TIMEOUT
  DISABLED
}

model User {
  id                     String                    @id @default(auto()) @map("_id") @db.ObjectId
  displayName            String?
  email                  String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  firstSeenAt            DateTime?
  lastSeenAt             DateTime?
  sessionCount           Int                       @default(0)
  isInternal             Boolean                   @default(false)
  acquisitionSource      String?
  socialAccounts         SocialAccount[]
  polymarketAccounts     PolymarketAccount[]
  polymarketChallenges   PolymarketLinkChallenge[]
  traderProfile          TraderProfile?
  positions              Position[]
  copiedTrades           CopyTrade[]               @relation("CopyTradeFollower")
  tradingRooms           TradingRoom[]             @relation("TradingRoomOwner")
  contractTransactions   ContractTransaction[]
  signalReplies          SignalReply[]
  signalReactions        SignalReaction[]
  signalBookmarks        SignalBookmark[]
  pulsePosts             PulsePost[]
  pulsePostReplies       PulsePostReply[]
  pulsePostReactions     PulsePostReaction[]
  pulsePostBookmarks     PulsePostBookmark[]
  followingUsers         UserFollow[]              @relation("UserFollowFollower")
  followerUsers          UserFollow[]              @relation("UserFollowFollowing")
  notifications          UserNotification[]        @relation("NotificationRecipient")
  triggeredNotifications UserNotification[]        @relation("NotificationActor")
  positionReplies        PositionReply[]
  preference             UserPreference?
  supportTickets         SupportTicket[]
  supportReplies         SupportTicketReply[]
  activityMediaItems     ActivityMediaItem[]
  omnistonQuoteEvents    OmnistonQuoteEvent[]
  tonVaultIntents        TonVaultIntent[]
  usageSessions          UsageSession[]
  usageEvents            UsageEvent[]
}

model SocialAccount {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @db.ObjectId
  platform       SocialPlatform
  platformUserId String
  username       String?
  profileUrl     String?
  authProvider   AuthProvider   @default(UNKNOWN)
  source         String?
  metadata       Json?
  firstSeenAt    DateTime?
  lastSeenAt     DateTime?
  sessionCount   Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: NoAction)
  usageSessions  UsageSession[]
  usageEvents    UsageEvent[]

  @@unique([platform, platformUserId])
  @@index([userId])
  @@index([authProvider])
  @@index([lastSeenAt])
}

model PolymarketAccount {
  id                    String                       @id @default(auto()) @map("_id") @db.ObjectId
  userId                String                       @db.ObjectId
  ownerAddress          String
  funderAddress         String                       @unique
  walletType            PolymarketWalletType
  chainId               Int                          @default(137)
  status                PolymarketAccountStatus      @default(LINKED)
  credentialsCiphertext String?
  credentialsVerifiedAt DateTime?
  profileName           String?
  profileUrl            String?
  linkedAt              DateTime                     @default(now())
  walletVerifiedAt      DateTime?
  disconnectedAt        DateTime?
  lastSyncedAt          DateTime?
  lastSyncError         String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  user                  User                         @relation(fields: [userId], references: [id], onDelete: NoAction)
  positions             PolymarketPositionSnapshot[]
  challenges            PolymarketLinkChallenge[]

  @@index([userId])
  @@index([ownerAddress])
  @@index([status])
  @@index([lastSyncedAt])
}

model PolymarketLinkChallenge {
  id                      String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId                  String                     @db.ObjectId
  accountId               String?                    @db.ObjectId
  purpose                 PolymarketChallengePurpose
  convictionAddress       String
  convictionChainId       Int
  polymarketOwnerAddress  String
  polymarketFunderAddress String
  polymarketWalletType    PolymarketWalletType
  nonce                   String                     @unique
  message                 String
  expiresAt               DateTime
  consumedAt              DateTime?
  createdAt               DateTime                   @default(now())
  user                    User                       @relation(fields: [userId], references: [id], onDelete: NoAction)
  account                 PolymarketAccount?         @relation(fields: [accountId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([accountId])
  @@index([purpose])
  @@index([expiresAt])
}

model PolymarketPositionSnapshot {
  id           String                  @id @default(auto()) @map("_id") @db.ObjectId
  accountId    String                  @db.ObjectId
  assetId      String
  conditionId  String?
  state        PolymarketPositionState
  outcome      String?
  size         String?
  averagePrice String?
  initialValue String?
  currentValue String?
  cashPnl      String?
  realizedPnl  String?
  currentPrice String?
  title        String?
  slug         String?
  iconUrl      String?
  eventSlug    String?
  endDate      DateTime?
  redeemable   Boolean                 @default(false)
  mergeable    Boolean                 @default(false)
  raw          Json?
  lastSyncedAt DateTime                @default(now())
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  account      PolymarketAccount       @relation(fields: [accountId], references: [id], onDelete: NoAction)

  @@unique([accountId, assetId, state])
  @@index([accountId])
  @@index([conditionId])
  @@index([state])
}

model TraderProfile {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @unique @db.ObjectId
  handle       String        @unique
  bio          String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction)
  tradeSignals TradeSignal[]
}

model Market {
  id                    String              @id @default(auto()) @map("_id") @db.ObjectId
  externalMarketId      String
  source                MarketSource
  title                 String
  description           String?
  category              String?
  status                MarketStatus        @default(ACTIVE)
  resolutionDate        DateTime?
  externalUrl           String?
  yesTokenId            String?
  noTokenId             String?
  slug                  String?
  conditionId           String?
  questionId            String?
  negativeRisk          Boolean?
  orderBookEnabled      Boolean             @default(false)
  acceptingOrders       Boolean             @default(false)
  orderPriceMinTickSize String?
  orderMinSize          String?
  lastTradePrice        String?
  bestBid               String?
  bestAsk               String?
  providerMetadata      String?
  syncedAt              DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  positions             Position[]
  signals               TradeSignal[]
  activityMediaItems    ActivityMediaItem[]
  marginRiskPolicy      MarginMarketPolicy?

  @@unique([source, externalMarketId])
  @@index([source])
  @@index([status])
  @@index([category])
  @@index([conditionId])
  @@index([questionId])
}

model MarginMarketPolicy {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  marketId                String                   @unique @db.ObjectId
  status                  MarginMarketPolicyStatus @default(DRAFT)
  expectedNegativeRisk    Boolean
  maxLeverageBps          Int                      @default(20000)
  threeXApproved          Boolean                  @default(false)
  maintenanceMarginBps    Int                      @default(3000)
  feeBps                  Int                      @default(100)
  minimumDepthAssets      String
  maximumSpreadBps        Int                      @default(500)
  maximumTwapDeviationBps Int                      @default(1000)
  maximumPriceAgeSeconds  Int                      @default(30)
  closeBufferSeconds      Int
  earliestResolutionAt    DateTime
  mandatoryCloseAt        DateTime
  maxMarketBorrowAssets   String
  maxAccountBorrowAssets  String
  maxCategoryBorrowAssets String
  maxVaultBorrowAssets    String
  approvedBy              String?
  notes                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  market                  Market                   @relation(fields: [marketId], references: [id], onDelete: NoAction)

  @@index([status])
  @@index([mandatoryCloseAt])
}

model Position {
  id                        String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId                    String                     @db.ObjectId
  marketId                  String                     @db.ObjectId
  side                      PositionSide
  quantity                  String
  averageEntryPrice         String?
  observedMarketPrice       String?
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode              @default(SPOT)
  leverageMultiplier        String?
  marginCollateral          String?
  notionalAmount            String?
  borrowedAmount            String?
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  status                    PositionStatus             @default(PENDING_EXECUTION)
  visibility                String?                    @default("PRIVATE")
  openedAt                  DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  user                      User                       @relation(fields: [userId], references: [id], onDelete: NoAction)
  market                    Market                     @relation(fields: [marketId], references: [id], onDelete: NoAction)
  sourceCopyIntents         CopyTrade[]                @relation("CopyTradeSourcePosition")
  resultingCopyTrade        CopyTrade?                 @relation("CopyTradeResultingPosition")
  executionAttempts         ExecutionAttempt[]         @relation("PositionExecutionAttempts")
  polymarketMarginExecution PolymarketMarginExecution?
  contractTransactions      ContractTransaction[]
  socialReplies             PositionReply[]

  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([executionMode])
  @@index([chainId])
}

model PolymarketMarginExecution {
  id                        String                         @id @default(auto()) @map("_id") @db.ObjectId
  positionId                String                         @unique @db.ObjectId
  idempotencyKey            String                         @unique
  authorizationNonce        String                         @unique
  authorizationDeadline     DateTime
  authorizationSigner       String
  authorizationSignature    String
  quoteId                   String
  maxSlippageBps            Int
  state                     PolymarketMarginExecutionState @default(AUTHORIZED)
  conditionId               String
  tokenId                   String
  vaultAddress              String
  adapterAddress            String
  loanId                    String?                        @unique
  custodyAddress            String?
  sessionSignerAddress      String?
  sessionSignerCiphertext   String?
  depositWalletAddress      String?
  clobCredentialsCiphertext String?
  relayerTransactionId      String?
  relayerOperation          String?
  signedOrderPayload        Json?
  clobOrderId               String?                        @unique
  clobTradeIds              Json?
  settlementTxHashes        Json?
  actualFillPrice           String?
  actualShares              String?
  actualSpentAssets         String?
  actualFeeAssets           String?
  fundingTxHash             String?
  custodyFundingTxHash      String?
  securityTransferTxHash    String?
  activationTxHash          String?
  failureCode               String?
  failureMessage            String?
  requestPayload            Json?
  responsePayload           Json?
  operationId               String?
  operationLockedUntil      DateTime?
  reservedAt                DateTime?
  orderSubmittedAt          DateTime?
  fillConfirmedAt           DateTime?
  securedAt                 DateTime?
  openedAt                  DateTime?
  closingAt                 DateTime?
  closedAt                  DateTime?
  activeCloseAttemptId      String?                        @db.ObjectId
  stopLossPrice             String?
  takeProfitPrice           String?
  lastReconciledAt          DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  position                  Position                       @relation(fields: [positionId], references: [id], onDelete: NoAction)
  closeAttempts             PolymarketCloseAttempt[]
  debtRepayments            PolymarketDebtRepayment[]
  riskControlAuthorizations PolymarketRiskControlAuthorization[]

  @@index([state])
  @@index([authorizationSigner])
  @@index([depositWalletAddress])
  @@index([lastReconciledAt])
}

model PolymarketDebtRepayment {
  id              String                    @id @default(auto()) @map("_id") @db.ObjectId
  executionId     String                    @db.ObjectId
  userId          String                    @db.ObjectId
  assets          String
  transactionHash String                    @unique
  confirmedAt     DateTime
  createdAt       DateTime                  @default(now())
  execution       PolymarketMarginExecution @relation(fields: [executionId], references: [id], onDelete: NoAction)

  @@index([executionId])
  @@index([userId])
}

model PolymarketRiskControlAuthorization {
  id                     String                    @id @default(auto()) @map("_id") @db.ObjectId
  executionId            String                    @db.ObjectId
  authorizationNonce     String                    @unique
  authorizationDeadline  DateTime
  authorizationSigner    String
  authorizationSignature String
  stopLossPrice          String?
  takeProfitPrice        String?
  createdAt              DateTime                  @default(now())
  execution              PolymarketMarginExecution @relation(fields: [executionId], references: [id], onDelete: NoAction)

  @@index([executionId])
  @@index([createdAt])
}

model PolymarketCloseAttempt {
  id                     String                    @id @default(auto()) @map("_id") @db.ObjectId
  executionId            String                    @db.ObjectId
  idempotencyKey         String                    @unique
  authorizationNonce     String                    @unique
  authorizationDeadline  DateTime
  authorizationSigner    String
  authorizationSignature String
  reason                 PolymarketCloseReason
  stage                  PolymarketCloseStage      @default(AUTHORIZED)
  maxSlippageBps         Int
  priceLimit             String
  minimumProceeds        String
  walletBaselineAssets   String?
  walletBaselineShares   String?
  signedOrderPayload     Json?
  clobOrderId            String?                   @unique
  clobTradeIds           Json?
  settlementTxHashes     Json?
  actualFillPrice        String?
  actualShares           String?
  actualProceeds         String?
  actualFeeAssets        String?
  vaultBeginTxHash       String?
  returnTxHash           String?
  vaultSettlementTxHash  String?
  relayerTransactionId   String?
  relayerOperation       String?
  failureCode            String?
  failureMessage         String?
  requestPayload         Json?
  responsePayload        Json?
  completedAt            DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  execution              PolymarketMarginExecution @relation(fields: [executionId], references: [id], onDelete: NoAction)

  @@index([executionId])
  @@index([reason])
  @@index([stage])
  @@index([createdAt])
}

model TradeSignal {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  traderProfileId String            @db.ObjectId
  marketId        String            @db.ObjectId
  roomId          String?           @db.ObjectId
  side            TradeSignalSide
  thesis          String
  convictionLevel Int?
  source          TradeSignalSource
  limitPrice      String?
  quantity        String?
  rationale       String?
  status          TradeSignalStatus @default(PUBLISHED)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  traderProfile   TraderProfile     @relation(fields: [traderProfileId], references: [id], onDelete: NoAction)
  market          Market            @relation(fields: [marketId], references: [id], onDelete: NoAction)
  room            TradingRoom?      @relation(fields: [roomId], references: [id], onDelete: NoAction)
  copyTrades      CopyTrade[]
  socialReplies   SignalReply[]
  socialReactions SignalReaction[]
  socialBookmarks SignalBookmark[]

  @@index([traderProfileId])
  @@index([marketId])
  @@index([roomId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model SignalReply {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  signalId     String            @db.ObjectId
  authorUserId String            @db.ObjectId
  body         String
  status       SignalReplyStatus @default(PUBLISHED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  signal       TradeSignal       @relation(fields: [signalId], references: [id], onDelete: NoAction)
  author       User              @relation(fields: [authorUserId], references: [id], onDelete: NoAction)

  @@index([signalId])
  @@index([authorUserId])
  @@index([status])
  @@index([createdAt])
}

model SignalReaction {
  id        String             @id @default(auto()) @map("_id") @db.ObjectId
  signalId  String             @db.ObjectId
  userId    String             @db.ObjectId
  type      SignalReactionType @default(LIKE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  signal    TradeSignal        @relation(fields: [signalId], references: [id], onDelete: NoAction)
  user      User               @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@unique([signalId, userId, type])
  @@index([signalId])
  @@index([userId])
  @@index([type])
}

model SignalBookmark {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  signalId  String      @db.ObjectId
  userId    String      @db.ObjectId
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  signal    TradeSignal @relation(fields: [signalId], references: [id], onDelete: NoAction)
  user      User        @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@unique([signalId, userId])
  @@index([signalId])
  @@index([userId])
}

model PulsePost {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  authorUserId String              @db.ObjectId
  body         String
  mediaUrl     String?
  mediaType    String?
  status       PulsePostStatus     @default(PUBLISHED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  author       User                @relation(fields: [authorUserId], references: [id], onDelete: NoAction)
  replies      PulsePostReply[]
  reactions    PulsePostReaction[]
  bookmarks    PulsePostBookmark[]

  @@index([authorUserId])
  @@index([status])
  @@index([createdAt])
}

model PulsePostReply {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  postId       String          @db.ObjectId
  authorUserId String          @db.ObjectId
  body         String
  status       PulsePostStatus @default(PUBLISHED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  post         PulsePost       @relation(fields: [postId], references: [id], onDelete: NoAction)
  author       User            @relation(fields: [authorUserId], references: [id], onDelete: NoAction)

  @@index([postId])
  @@index([authorUserId])
  @@index([status])
  @@index([createdAt])
}

model PulsePostReaction {
  id        String                @id @default(auto()) @map("_id") @db.ObjectId
  postId    String                @db.ObjectId
  userId    String                @db.ObjectId
  type      PulsePostReactionType @default(LIKE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  post      PulsePost             @relation(fields: [postId], references: [id], onDelete: NoAction)
  user      User                  @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
  @@index([type])
}

model PulsePostBookmark {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  postId    String    @db.ObjectId
  userId    String    @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  post      PulsePost @relation(fields: [postId], references: [id], onDelete: NoAction)
  user      User      @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model UserFollow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  followerId  String   @db.ObjectId
  followingId String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  follower    User     @relation("UserFollowFollower", fields: [followerId], references: [id], onDelete: NoAction)
  following   User     @relation("UserFollowFollowing", fields: [followingId], references: [id], onDelete: NoAction)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserNotification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  actorUserId String?   @db.ObjectId
  type        String
  entityType  String?
  entityId    String?
  message     String
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  recipient   User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: NoAction)
  actor       User?     @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([actorUserId])
  @@index([type])
  @@index([createdAt])
}

model PositionReply {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  positionId   String   @db.ObjectId
  authorUserId String   @db.ObjectId
  body         String
  status       String   @default("PUBLISHED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  position     Position @relation(fields: [positionId], references: [id], onDelete: NoAction)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: NoAction)

  @@index([positionId])
  @@index([authorUserId])
  @@index([status])
  @@index([createdAt])
}

model CopyTrade {
  id                        String             @id @default(auto()) @map("_id") @db.ObjectId
  followerId                String             @db.ObjectId
  sourcePositionId          String             @db.ObjectId
  sourceSignalId            String?            @db.ObjectId
  requestedQuantity         String
  executedQuantity          String?
  executionPrice            String?
  observedMarketPrice       String?
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode      @default(SPOT)
  leverageMultiplier        String?
  marginCollateral          String?
  notionalAmount            String?
  borrowedAmount            String?
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  resultingPositionId       String?            @unique @db.ObjectId
  status                    CopyTradeStatus    @default(PENDING_EXECUTION)
  externalOrderId           String?
  errorMessage              String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  follower                  User               @relation("CopyTradeFollower", fields: [followerId], references: [id], onDelete: NoAction)
  sourcePosition            Position           @relation("CopyTradeSourcePosition", fields: [sourcePositionId], references: [id], onDelete: NoAction)
  sourceSignal              TradeSignal?       @relation(fields: [sourceSignalId], references: [id], onDelete: NoAction)
  resultingPosition         Position?          @relation("CopyTradeResultingPosition", fields: [resultingPositionId], references: [id], onDelete: NoAction)
  executionAttempts         ExecutionAttempt[] @relation("CopyTradeExecutionAttempts")

  @@index([followerId])
  @@index([sourcePositionId])
  @@index([sourceSignalId])
  @@index([status])
  @@index([executionMode])
  @@index([chainId])
}

model ExecutionAttempt {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  targetType           ExecutionTargetType
  positionId           String?                @db.ObjectId
  copyTradeId          String?                @db.ObjectId
  adapterId            String
  executionMode        ExecutionMode
  chainId              Int?
  walletAddress        String?
  requestedQuantity    String?
  leverageMultiplier   String?
  marginCollateral     String?
  notionalAmount       String?
  borrowedAmount       String?
  observedMarketPrice  String?
  status               ExecutionAttemptStatus @default(BLOCKED)
  failureCode          String?
  failureMessage       String?
  externalOrderId      String?
  chainTransactionHash String?
  requestPayload       Json?
  responsePayload      Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  position             Position?              @relation("PositionExecutionAttempts", fields: [positionId], references: [id], onDelete: NoAction)
  copyTrade            CopyTrade?             @relation("CopyTradeExecutionAttempts", fields: [copyTradeId], references: [id], onDelete: NoAction)

  @@index([targetType])
  @@index([positionId])
  @@index([copyTradeId])
  @@index([status])
  @@index([chainId])
}

model TradingRoom {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String        @db.ObjectId
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("TradingRoomOwner", fields: [ownerId], references: [id], onDelete: NoAction)
  signals     TradeSignal[]

  @@index([ownerId])
}

model UserPreference {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @unique @db.ObjectId
  topics              String[]
  regions             String[]
  sports              String[]
  mediaTypes          String[]
  newsIntervalMinutes Int      @default(20)
  notifyInActivity    Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([updatedAt])
}

model ActivityMediaItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @db.ObjectId
  marketId   String?  @db.ObjectId
  kind       String
  title      String
  summary    String
  imageUrl   String?
  videoUrl   String?
  mediaBrief Json?
  source     String   @default("CONVICTION_AI")
  status     String   @default("PUBLISHED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: NoAction)
  market     Market?  @relation(fields: [marketId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([marketId])
  @@index([kind])
  @@index([status])
  @@index([createdAt])
}

model UsageSession {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  clientSessionId String         @unique
  userId          String?        @db.ObjectId
  socialAccountId String?        @db.ObjectId
  authProvider    AuthProvider   @default(UNKNOWN)
  source          String         @default("WEB_APP")
  entryPath       String?
  currentPath     String?
  userAgent       String?
  referrer        String?
  startedAt       DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  endedAt         DateTime?
  durationSeconds Int            @default(0)
  eventCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User?          @relation(fields: [userId], references: [id], onDelete: NoAction)
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: NoAction)
  events          UsageEvent[]

  @@index([userId])
  @@index([socialAccountId])
  @@index([authProvider])
  @@index([source])
  @@index([startedAt])
  @@index([lastSeenAt])
}

model UsageEvent {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  sessionId       String?        @db.ObjectId
  clientSessionId String
  userId          String?        @db.ObjectId
  socialAccountId String?        @db.ObjectId
  type            UsageEventType
  area            String
  path            String?
  label           String?
  value           Float?
  metadata        Json?
  createdAt       DateTime       @default(now())
  session         UsageSession?  @relation(fields: [sessionId], references: [id], onDelete: NoAction)
  user            User?          @relation(fields: [userId], references: [id], onDelete: NoAction)
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: NoAction)

  @@index([sessionId])
  @@index([clientSessionId])
  @@index([userId])
  @@index([socialAccountId])
  @@index([type])
  @@index([area])
  @@index([createdAt])
}

model OmnistonQuoteEvent {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?             @db.ObjectId
  platform       SocialPlatform      @default(TELEGRAM)
  platformUserId String?
  username       String?
  source         String              @default("TELEGRAM_BOT")
  fromAsset      String
  toAsset        String
  amountUnits    String
  status         OmnistonQuoteStatus
  inputUnits     String?
  outputUnits    String?
  settlement     String?
  resolverName   String?
  quoteId        String?
  gasBudget      String?
  routeCount     Int?
  errorCode      String?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User?               @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([platform])
  @@index([platformUserId])
  @@index([status])
  @@index([fromAsset])
  @@index([toAsset])
  @@index([createdAt])
}

model TelegramChat {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  chatId     String           @unique
  title      String?
  type       String?
  role       TelegramChatRole @default(GENERAL)
  isActive   Boolean          @default(true)
  lastSeenAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([lastSeenAt])
}

model TonVaultIntent {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
