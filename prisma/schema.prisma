  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([telegramUserId])
  @@index([tonAddress])
  @@index([asset])
  @@index([status])
  @@index([createdAt])
}

model SupportTicket {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  userId         String?              @db.ObjectId
  wallet         String?
  email          String
  subject        String
  summary        String
  transcript     String?
  status         String               @default("OPEN")
  telegramSentAt DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  autoCloseAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User?                @relation(fields: [userId], references: [id], onDelete: NoAction)
  replies        SupportTicketReply[]

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([autoCloseAt])
  @@index([createdAt])
}

model SupportTicketReply {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  ticketId     String        @db.ObjectId
  authorType   String
  authorUserId String?       @db.ObjectId
  authorName   String?
  subject      String?
  body         String
  source       String        @default("APP")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User?         @relation(fields: [authorUserId], references: [id], onDelete: NoAction)

  @@index([ticketId])
  @@index([authorUserId])
  @@index([authorType])
  @@index([createdAt])
}

model ContractDeployment {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  chainId       Int
  role          ContractRole
  address       String
  label         String?
  tokenSymbol   String?
  tokenDecimals Int?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([chainId, role, address])
  @@index([chainId])
  @@index([role])
  @@index([isActive])
}

model ContractTransaction {
  id              String                    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?                   @db.ObjectId
  positionId      String?                   @db.ObjectId
  chainId         Int
  contractAddress String
  walletAddress   String
  transactionHash String?
  type            ContractTransactionType
  status          ContractTransactionStatus @default(PREPARED)
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User?                     @relation(fields: [userId], references: [id], onDelete: NoAction)
  position        Position?                 @relation(fields: [positionId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([positionId])
  @@index([chainId])
  @@index([status])
  @@index([transactionHash])
}
