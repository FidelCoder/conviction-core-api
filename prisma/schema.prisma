generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  TELEGRAM
  FARCASTER
}

enum MarketSource {
  POLYMARKET
  KALSHI
}

enum MarketStatus {
  ACTIVE
  CLOSED
  SETTLED
  CANCELLED
}

enum PositionSide {
  YES
  NO
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum TradeSignalSide {
  YES
  NO
}

enum TradeSignalStatus {
  PUBLISHED
  CANCELLED
  EXPIRED
}

enum CopyTradeStatus {
  REQUESTED
  EXECUTED
  FAILED
  CANCELLED
}

model User {
  id             String          @id @default(cuid())
  displayName    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  traderProfile  TraderProfile?
  positions      Position[]
  copiedTrades   CopyTrade[]     @relation("CopyTradeFollower")
  tradingRooms   TradingRoom[]   @relation("TradingRoomOwner")
}

model SocialAccount {
  id             String         @id @default(cuid())
  userId         String
  platform       SocialPlatform
  platformUserId String
  username       String?
  profileUrl     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, platformUserId])
  @@index([userId])
}

model TraderProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  handle       String        @unique
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeSignals TradeSignal[]
}

model Market {
  id               String        @id @default(cuid())
  externalMarketId String
  source           MarketSource
  title            String
  description      String?
  category         String?
  status           MarketStatus  @default(ACTIVE)
  resolutionDate   DateTime?
  externalUrl      String?
  yesTokenId       String?
  noTokenId        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  positions        Position[]
  signals          TradeSignal[]

  @@unique([source, externalMarketId])
  @@index([source])
  @@index([status])
  @@index([category])
}

model Position {
  id                String         @id @default(cuid())
  userId            String
  marketId          String
  side              PositionSide
  quantity          Decimal        @db.Decimal(18, 8)
  averageEntryPrice Decimal        @db.Decimal(18, 8)
  status            PositionStatus @default(OPEN)
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  market            Market         @relation(fields: [marketId], references: [id], onDelete: Restrict)
  sourceCopyTrade   CopyTrade?

  @@index([userId])
  @@index([marketId])
  @@index([status])
}

model TradeSignal {
  id              String            @id @default(cuid())
  traderProfileId String
  marketId        String
  roomId          String?
  side            TradeSignalSide
  limitPrice      Decimal?          @db.Decimal(18, 8)
  quantity        Decimal?          @db.Decimal(18, 8)
  rationale       String?
  status          TradeSignalStatus @default(PUBLISHED)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  traderProfile   TraderProfile     @relation(fields: [traderProfileId], references: [id], onDelete: Cascade)
  market          Market            @relation(fields: [marketId], references: [id], onDelete: Restrict)
  room            TradingRoom?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  copyTrades      CopyTrade[]

  @@index([traderProfileId])
  @@index([marketId])
  @@index([roomId])
  @@index([status])
}

model CopyTrade {
  id                  String          @id @default(cuid())
  followerId          String
  sourceSignalId      String
  requestedQuantity   Decimal         @db.Decimal(18, 8)
  executedQuantity    Decimal?        @db.Decimal(18, 8)
  executionPrice      Decimal?        @db.Decimal(18, 8)
  resultingPositionId String?         @unique
  status              CopyTradeStatus @default(REQUESTED)
  externalOrderId     String?
  errorMessage        String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  follower            User            @relation("CopyTradeFollower", fields: [followerId], references: [id], onDelete: Cascade)
  sourceSignal        TradeSignal     @relation(fields: [sourceSignalId], references: [id], onDelete: Restrict)
  resultingPosition   Position?       @relation(fields: [resultingPositionId], references: [id], onDelete: SetNull)

  @@index([followerId])
  @@index([sourceSignalId])
  @@index([status])
}

model TradingRoom {
  id          String        @id @default(cuid())
  ownerId     String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("TradingRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  signals     TradeSignal[]

  @@index([ownerId])
}
