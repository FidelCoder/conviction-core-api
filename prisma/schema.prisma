generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  TELEGRAM
  FARCASTER
}

enum MarketSource {
  POLYMARKET
  KALSHI
}

enum MarketStatus {
  ACTIVE
  CLOSED
  SETTLED
  CANCELLED
}

enum PositionSide {
  YES
  NO
}

enum PositionStatus {
  PENDING_EXECUTION
  EXECUTED
  FAILED
  CANCELLED
}

enum ExecutionMode {
  SPOT
  MARGIN
}

enum ExecutionTargetType {
  POSITION
  COPY_TRADE
}

enum ExecutionAttemptStatus {
  BLOCKED
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum TradeSignalSide {
  YES
  NO
}

enum TradeSignalStatus {
  PUBLISHED
  CANCELLED
  EXPIRED
}

enum TradeSignalSource {
  TELEGRAM
  FARCASTER
  WEB
}

enum CopyTradeStatus {
  PENDING_EXECUTION
  EXECUTED
  FAILED
  CANCELLED
}

enum ContractRole {
  MARGIN_VAULT
  EXECUTION_ADAPTER
  COLLATERAL_TOKEN
}

enum ContractTransactionStatus {
  PREPARED
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum ContractTransactionType {
  COLLATERAL_APPROVAL
  DEPOSIT
  MARGIN_INTENT
  CLOSE_INTENT
  LIQUIDATION
}

model User {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  displayName          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  socialAccounts       SocialAccount[]
  traderProfile        TraderProfile?
  positions            Position[]
  copiedTrades         CopyTrade[]           @relation("CopyTradeFollower")
  tradingRooms         TradingRoom[]         @relation("TradingRoomOwner")
  contractTransactions ContractTransaction[]
}

model SocialAccount {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @db.ObjectId
  platform       SocialPlatform
  platformUserId String
  username       String?
  profileUrl     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@unique([platform, platformUserId])
  @@index([userId])
}

model TraderProfile {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @unique @db.ObjectId
  handle       String        @unique
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction)
  tradeSignals TradeSignal[]
}

model Market {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  externalMarketId      String
  source                MarketSource
  title                 String
  description           String?
  category              String?
  status                MarketStatus  @default(ACTIVE)
  resolutionDate        DateTime?
  externalUrl           String?
  yesTokenId            String?
  noTokenId             String?
  slug                  String?
  conditionId           String?
  questionId            String?
  orderBookEnabled      Boolean       @default(false)
  acceptingOrders       Boolean       @default(false)
  orderPriceMinTickSize String?
  orderMinSize          String?
  lastTradePrice        String?
  bestBid               String?
  bestAsk               String?
  syncedAt              DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  positions             Position[]
  signals               TradeSignal[]

  @@unique([source, externalMarketId])
  @@index([source])
  @@index([status])
  @@index([category])
  @@index([conditionId])
  @@index([questionId])
}

model Position {
  id                        String                @id @default(auto()) @map("_id") @db.ObjectId
  userId                    String                @db.ObjectId
  marketId                  String                @db.ObjectId
  side                      PositionSide
  quantity                  String
  averageEntryPrice         String?
  observedMarketPrice       String?
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode         @default(SPOT)
  leverageMultiplier        String?
  marginCollateral          String?
  notionalAmount            String?
  borrowedAmount            String?
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  status                    PositionStatus        @default(PENDING_EXECUTION)
  openedAt                  DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  user                      User                  @relation(fields: [userId], references: [id], onDelete: NoAction)
  market                    Market                @relation(fields: [marketId], references: [id], onDelete: NoAction)
  sourceCopyIntents         CopyTrade[]           @relation("CopyTradeSourcePosition")
  resultingCopyTrade        CopyTrade?            @relation("CopyTradeResultingPosition")
  executionAttempts         ExecutionAttempt[]    @relation("PositionExecutionAttempts")
  contractTransactions      ContractTransaction[]

  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([executionMode])
  @@index([chainId])
}

model TradeSignal {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  traderProfileId String            @db.ObjectId
  marketId        String            @db.ObjectId
  roomId          String?           @db.ObjectId
  side            TradeSignalSide
  thesis          String
  convictionLevel Int?
  source          TradeSignalSource
  limitPrice      String?
  quantity        String?
  rationale       String?
  status          TradeSignalStatus @default(PUBLISHED)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  traderProfile   TraderProfile     @relation(fields: [traderProfileId], references: [id], onDelete: NoAction)
  market          Market            @relation(fields: [marketId], references: [id], onDelete: NoAction)
  room            TradingRoom?      @relation(fields: [roomId], references: [id], onDelete: NoAction)
  copyTrades      CopyTrade[]

  @@index([traderProfileId])
  @@index([marketId])
  @@index([roomId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model CopyTrade {
  id                        String             @id @default(auto()) @map("_id") @db.ObjectId
  followerId                String             @db.ObjectId
  sourcePositionId          String             @db.ObjectId
  sourceSignalId            String?            @db.ObjectId
  requestedQuantity         String
  executedQuantity          String?
  executionPrice            String?
  observedMarketPrice       String?
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode      @default(SPOT)
  leverageMultiplier        String?
  marginCollateral          String?
  notionalAmount            String?
  borrowedAmount            String?
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  resultingPositionId       String?            @unique @db.ObjectId
  status                    CopyTradeStatus    @default(PENDING_EXECUTION)
  externalOrderId           String?
  errorMessage              String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  follower                  User               @relation("CopyTradeFollower", fields: [followerId], references: [id], onDelete: NoAction)
  sourcePosition            Position           @relation("CopyTradeSourcePosition", fields: [sourcePositionId], references: [id], onDelete: NoAction)
  sourceSignal              TradeSignal?       @relation(fields: [sourceSignalId], references: [id], onDelete: NoAction)
  resultingPosition         Position?          @relation("CopyTradeResultingPosition", fields: [resultingPositionId], references: [id], onDelete: NoAction)
  executionAttempts         ExecutionAttempt[] @relation("CopyTradeExecutionAttempts")

  @@index([followerId])
  @@index([sourcePositionId])
  @@index([sourceSignalId])
  @@index([status])
  @@index([executionMode])
  @@index([chainId])
}

model ExecutionAttempt {
  id                   String                 @id @default(auto()) @map("_id") @db.ObjectId
  targetType           ExecutionTargetType
  positionId           String?                @db.ObjectId
  copyTradeId          String?                @db.ObjectId
  adapterId            String
  executionMode        ExecutionMode
  chainId              Int?
  walletAddress        String?
  requestedQuantity    String?
  leverageMultiplier   String?
  marginCollateral     String?
  notionalAmount       String?
  borrowedAmount       String?
  observedMarketPrice  String?
  status               ExecutionAttemptStatus @default(BLOCKED)
  failureCode          String?
  failureMessage       String?
  externalOrderId      String?
  chainTransactionHash String?
  requestPayload       Json?
  responsePayload      Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  position             Position?              @relation("PositionExecutionAttempts", fields: [positionId], references: [id], onDelete: NoAction)
  copyTrade            CopyTrade?             @relation("CopyTradeExecutionAttempts", fields: [copyTradeId], references: [id], onDelete: NoAction)

  @@index([targetType])
  @@index([positionId])
  @@index([copyTradeId])
  @@index([status])
  @@index([chainId])
}

model TradingRoom {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String        @db.ObjectId
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("TradingRoomOwner", fields: [ownerId], references: [id], onDelete: NoAction)
  signals     TradeSignal[]

  @@index([ownerId])
}

model ContractDeployment {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  chainId       Int
  role          ContractRole
  address       String
  label         String?
  tokenSymbol   String?
  tokenDecimals Int?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([chainId, role, address])
  @@index([chainId])
  @@index([role])
  @@index([isActive])
}

model ContractTransaction {
  id              String                    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?                   @db.ObjectId
  positionId      String?                   @db.ObjectId
  chainId         Int
  contractAddress String
  walletAddress   String
  transactionHash String?
  type            ContractTransactionType
  status          ContractTransactionStatus @default(PREPARED)
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  user            User?                     @relation(fields: [userId], references: [id], onDelete: NoAction)
  position        Position?                 @relation(fields: [positionId], references: [id], onDelete: NoAction)

  @@index([userId])
  @@index([positionId])
  @@index([chainId])
  @@index([status])
  @@index([transactionHash])
}
