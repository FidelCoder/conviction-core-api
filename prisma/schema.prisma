generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  TELEGRAM
  FARCASTER
}

enum MarketSource {
  POLYMARKET
  KALSHI
}

enum MarketStatus {
  ACTIVE
  CLOSED
  SETTLED
  CANCELLED
}

enum PositionSide {
  YES
  NO
}

enum PositionStatus {
  PENDING_EXECUTION
  EXECUTED
  FAILED
  CANCELLED
}

enum TradeSignalSide {
  YES
  NO
}

enum TradeSignalStatus {
  PUBLISHED
  CANCELLED
  EXPIRED
}

enum TradeSignalSource {
  TELEGRAM
  FARCASTER
  WEB
}

enum CopyTradeStatus {
  PENDING_EXECUTION
  EXECUTED
  FAILED
  CANCELLED
}

enum ExecutionMode {
  SPOT
  MARGIN
}

enum ExecutionAttemptStatus {
  CREATED
  BLOCKED
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

enum ExecutionAttemptTarget {
  POSITION
  COPY_TRADE
}

model User {
  id             String          @id @default(cuid())
  displayName    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  traderProfile  TraderProfile?
  positions      Position[]
  copiedTrades   CopyTrade[]     @relation("CopyTradeFollower")
  tradingRooms   TradingRoom[]   @relation("TradingRoomOwner")
}

model SocialAccount {
  id             String         @id @default(cuid())
  userId         String
  platform       SocialPlatform
  platformUserId String
  username       String?
  profileUrl     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, platformUserId])
  @@index([userId])
}

model TraderProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  handle       String        @unique
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeSignals TradeSignal[]
}

model Market {
  id                    String        @id @default(cuid())
  externalMarketId      String
  source                MarketSource
  title                 String
  description           String?
  category              String?
  status                MarketStatus  @default(ACTIVE)
  resolutionDate        DateTime?
  externalUrl           String?
  yesTokenId            String?
  noTokenId             String?
  slug                  String?
  conditionId           String?
  questionId            String?
  orderBookEnabled      Boolean       @default(false)
  acceptingOrders       Boolean       @default(false)
  orderPriceMinTickSize Decimal?      @db.Decimal(18, 8)
  orderMinSize          Decimal?      @db.Decimal(18, 8)
  lastTradePrice        Decimal?      @db.Decimal(18, 8)
  bestBid               Decimal?      @db.Decimal(18, 8)
  bestAsk               Decimal?      @db.Decimal(18, 8)
  syncedAt              DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  positions             Position[]
  signals               TradeSignal[]

  @@unique([source, externalMarketId])
  @@index([source])
  @@index([status])
  @@index([category])
  @@index([conditionId])
  @@index([questionId])
}

model Position {
  id                        String         @id @default(cuid())
  userId                    String
  marketId                  String
  side                      PositionSide
  quantity                  Decimal        @db.Decimal(18, 8)
  averageEntryPrice         Decimal?       @db.Decimal(18, 8)
  observedMarketPrice       Decimal?       @db.Decimal(18, 8)
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode  @default(SPOT)
  leverageMultiplier        Decimal?       @db.Decimal(10, 4)
  marginCollateral          Decimal?       @db.Decimal(18, 8)
  notionalAmount            Decimal?       @db.Decimal(18, 8)
  borrowedAmount            Decimal?       @db.Decimal(18, 8)
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  status                    PositionStatus @default(PENDING_EXECUTION)
  openedAt                  DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  user                      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  market                    Market         @relation(fields: [marketId], references: [id], onDelete: Restrict)
  executionAttempts         ExecutionAttempt[]
  sourceCopyIntents         CopyTrade[]    @relation("CopyTradeSourcePosition")
  resultingCopyTrade        CopyTrade?     @relation("CopyTradeResultingPosition")

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([chainId])
  @@index([executionMode])
}

model TradeSignal {
  id              String            @id @default(cuid())
  traderProfileId String
  marketId        String
  roomId          String?
  side            TradeSignalSide
  thesis          String
  convictionLevel Int?
  source          TradeSignalSource
  limitPrice      Decimal?          @db.Decimal(18, 8)
  quantity        Decimal?          @db.Decimal(18, 8)
  rationale       String?
  status          TradeSignalStatus @default(PUBLISHED)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  traderProfile   TraderProfile     @relation(fields: [traderProfileId], references: [id], onDelete: Cascade)
  market          Market            @relation(fields: [marketId], references: [id], onDelete: Restrict)
  room            TradingRoom?      @relation(fields: [roomId], references: [id], onDelete: SetNull)
  copyTrades      CopyTrade[]

  @@index([traderProfileId])
  @@index([marketId])
  @@index([roomId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model CopyTrade {
  id                        String          @id @default(cuid())
  followerId                String
  sourcePositionId          String
  sourceSignalId            String?
  requestedQuantity         Decimal         @db.Decimal(18, 8)
  executedQuantity          Decimal?        @db.Decimal(18, 8)
  executionPrice            Decimal?        @db.Decimal(18, 8)
  observedMarketPrice       Decimal?        @db.Decimal(18, 8)
  observedMarketPriceSource String?
  observedMarketPriceAt     DateTime?
  chainId                   Int?
  walletAddress             String?
  executionMode             ExecutionMode   @default(SPOT)
  leverageMultiplier        Decimal?        @db.Decimal(10, 4)
  marginCollateral          Decimal?        @db.Decimal(18, 8)
  notionalAmount            Decimal?        @db.Decimal(18, 8)
  borrowedAmount            Decimal?        @db.Decimal(18, 8)
  executionAdapterId        String?
  chainTransactionHash      String?
  idempotencyKey            String?
  resultingPositionId       String?         @unique
  status                    CopyTradeStatus @default(PENDING_EXECUTION)
  externalOrderId           String?
  errorMessage              String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  follower                  User            @relation("CopyTradeFollower", fields: [followerId], references: [id], onDelete: Cascade)
  sourcePosition            Position        @relation("CopyTradeSourcePosition", fields: [sourcePositionId], references: [id], onDelete: Restrict)
  sourceSignal              TradeSignal?    @relation(fields: [sourceSignalId], references: [id], onDelete: SetNull)
  resultingPosition         Position?       @relation("CopyTradeResultingPosition", fields: [resultingPositionId], references: [id], onDelete: SetNull)
  executionAttempts         ExecutionAttempt[]

  @@unique([followerId, idempotencyKey])
  @@index([followerId])
  @@index([sourcePositionId])
  @@index([sourceSignalId])
  @@index([status])
  @@index([chainId])
  @@index([executionMode])
}

model ExecutionAttempt {
  id                   String                 @id @default(cuid())
  targetType           ExecutionAttemptTarget
  positionId           String?
  copyTradeId          String?
  adapterId            String
  executionMode        ExecutionMode
  chainId              Int?
  walletAddress        String?
  requestedQuantity    Decimal?               @db.Decimal(18, 8)
  leverageMultiplier   Decimal?               @db.Decimal(10, 4)
  marginCollateral     Decimal?               @db.Decimal(18, 8)
  notionalAmount       Decimal?               @db.Decimal(18, 8)
  borrowedAmount       Decimal?               @db.Decimal(18, 8)
  observedMarketPrice  Decimal?               @db.Decimal(18, 8)
  status               ExecutionAttemptStatus @default(CREATED)
  failureCode          String?
  failureMessage       String?
  externalOrderId      String?
  chainTransactionHash String?
  requestPayload       Json?
  responsePayload      Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  position             Position?              @relation(fields: [positionId], references: [id], onDelete: Cascade)
  copyTrade            CopyTrade?             @relation(fields: [copyTradeId], references: [id], onDelete: Cascade)

  @@index([targetType])
  @@index([positionId])
  @@index([copyTradeId])
  @@index([adapterId])
  @@index([status])
  @@index([chainId])
  @@index([createdAt])
}

model TradingRoom {
  id          String        @id @default(cuid())
  ownerId     String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation("TradingRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  signals     TradeSignal[]

  @@index([ownerId])
}
