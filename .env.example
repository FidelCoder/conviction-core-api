NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DATABASE_URL=mongodb://127.0.0.1:27017/conviction_markets?replicaSet=rs0&directConnection=true
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_MARKETS_SYNC_LIMIT=250
POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_CREDENTIALS_ENCRYPTION_KEY=
MARKET_SYNC_TOKEN=

# Optional contract configuration. Leave empty until real deployments exist.
CONVICTION_VAULT_ADDRESS=
CONVICTION_EXECUTION_ADAPTER_ADDRESS=
CONVICTION_EXECUTION_MODE=disabled
CONVICTION_EXECUTION_SIGNER_PRIVATE_KEY=
CONVICTION_VAULT_OWNER=
BASE_SEPOLIA_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
BASE_MAINNET_RPC_URL=
DEPLOYER_PRIVATE_KEY=

# Production venue execution. These are not required for testnet vault intent testing.
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_API_SECRET=
POLYMARKET_CLOB_API_PASSPHRASE=
POLYMARKET_CLOB_FUNDER_ADDRESS=

# Production Polygon pUSD margin execution. Keep CONVICTION_EXECUTION_MODE disabled
# until every address is independently verified and the readiness endpoint is green.
POLYMARKET_PUSD_VAULT_ADDRESS=
POLYMARKET_EXECUTION_ADAPTER_ADDRESS=
POLYMARKET_EXECUTION_SIGNER_PRIVATE_KEY=
POLYMARKET_EXECUTION_KEY_ENCRYPTION_KEY=
POLYMARKET_PUSD_ADDRESS=0xC011a7E12a19f7B1f670d46F03B03f3342E82DFB
POLYMARKET_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYMARKET_EXCHANGE_V2_ADDRESS=0xE111180000d2663C0091e4f400237545B87B996B
POLYMARKET_NEG_RISK_EXCHANGE_V2_ADDRESS=0xe2222d279d744050d28e00520010520000310F59
POLYMARKET_NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296
POLYMARKET_DEPOSIT_WALLET_FACTORY_ADDRESS=0x00000000000Fb5C9ADea0298D729A0CB3823Cc07
POLYMARKET_GOVERNANCE_ADDRESS=
POLYMARKET_GUARDIAN_ADDRESS=
POLYMARKET_RISK_MANAGER_ADDRESS=
POLYMARKET_LIFECYCLE_ENABLED=false
POLYMARKET_ACTIVE_REPAY_ENABLED=false
POLYMARKET_CANARY_PASSED=false
POLYMARKET_CANARY_MAX_ASSETS=5
# Comma-separated lowercase/uppercase EVM addresses and Polygon condition IDs.
# While CANARY_PASSED is false, both lists are mandatory and markets must contain 1-5 IDs.
POLYMARKET_CANARY_ALLOWED_WALLETS=
POLYMARKET_CANARY_CONDITION_IDS=
# Initial production limits remain active after the canary flag changes.
POLYMARKET_RELEASE_MAX_LEVERAGE_BPS=20000
POLYMARKET_RELEASE_MAX_POSITION_ASSETS=25
POLYMARKET_RELEASE_MAX_TVL_ASSETS=1000
POLYMARKET_RELEASE_MAX_UTILIZATION_BPS=5000
POLYMARKET_RELEASE_DAILY_LOSS_LIMIT_ASSETS=25
POLYMARKET_DIRECT_LIQUIDATION_MAX_ASSETS=250
POLYMARKET_MIN_RESERVE_BPS=1000
POLYMARKET_BUILDER_TAKER_FEE_BPS=0
POLYMARKET_RELAYER_API_URL=https://relayer-v2.polymarket.com
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
POLYMARKET_BUILDER_CODE=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_API_SECRET=
POLYMARKET_BUILDER_API_PASSPHRASE=

# Telegram-only human support escalation. Keep both empty locally unless testing alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
CORE_PUBLIC_URL=https://conviction-core-api.vercel.app
CRON_SECRET=replace-with-random-secret-at-least-16-chars
ADMIN_DASHBOARD_TOKEN=replace-with-random-admin-token-at-least-24-chars

# STON.fi Omniston quote-only Telegram commands. Keep swap execution disabled.
OMNISTON_ENABLED=true
OMNISTON_NETWORK=mainnet
OMNISTON_ROUTING_MODE=quote_only
OMNISTON_API_URL=wss://omni-ws.ston.fi
OMNISTON_QUOTE_TIMEOUT_MS=8000
