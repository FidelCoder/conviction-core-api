{
  "buildCommand": "npm run db:generate && npm run build",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "crons": [
    {
      "path": "/ops/markets/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/telegram/market-digest",
      "schedule": "0 9 * * *"
    }
  ]
}
